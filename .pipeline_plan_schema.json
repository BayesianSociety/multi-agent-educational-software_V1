{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelinePlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "roles",
    "required_outputs",
    "dependencies"
  ],
  "properties": {
    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "required_outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "uniqueItems": true
      }
    }
  }
}
