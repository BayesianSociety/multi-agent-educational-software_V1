version: \"3.9\"

services:
  backend:
    image: node:20-alpine
    working_dir: /workspace/backend
    command: [\"sh\", \"-lc\", \"npm ci && npm run dev\"]
    environment:
      - NODE_ENV=development
      - PORT=3001
      - DATABASE_URL=file:/workspace/backend/dev.db
    volumes:
      - ./:/workspace
    ports:
      - \"3001:3001\"

  frontend:
    image: node:20-alpine
    working_dir: /workspace/frontend
    command: [\"sh\", \"-lc\", \"npm ci && npm run dev -- --host 0.0.0.0 --port 3000\"]
    environment:
      - NODE_ENV=development
      - PORT=3000
      - VITE_API_BASE_URL=http://backend:3001
    volumes:
      - ./:/workspace
    ports:
      - \"3000:3000\"
    depends_on:
      - backend
EOF

