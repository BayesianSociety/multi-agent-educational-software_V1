generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Level {
  id           Int    @id
  title        String
  narrative    String
  startX       Int
  goalX        Int
  blockedTiles String
}

model Progress {
  id            Int      @id @default(1)
  unlockedLevel Int      @default(1)
  updatedAt     DateTime @updatedAt
}
